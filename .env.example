# Supabase Configuration
# Get these values from your Supabase project settings: https://app.supabase.com/project/_/settings/api

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Storage bucket name (defaults to 'course-images')
# VITE_IMAGES_BUCKET=course-images

# Google Maps — address autocomplete + map pin on the public course page.
# Two SEPARATE keys with different restrictions:
#   1. Server-side (Places API, kept off the client) — set as a Supabase secret:
#        supabase secrets set GOOGLE_PLACES_API_KEY=...   # restrict to Places API (New)
#   2. Client-side (Maps Embed API only) — referrer-locked to your domains.
#      The Embed API is free, so exposing this key carries no cost.
VITE_GOOGLE_MAPS_EMBED_KEY=your-maps-embed-key-here

# Stripe — client-side publishable key (safe to expose; it ships in the bundle).
# Required for paid checkout: without it every paid signup shows "Betaling er
# ikke tilgjengelig", and production builds fail on purpose (vite.config.ts).
# Test mode: https://dashboard.stripe.com/test/apikeys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your-key-here

# Stripe Billing — platform subscription for Pro sellers (server-side Supabase secrets).
#   supabase secrets set STRIPE_SECRET_KEY=sk_test_...
#   supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
#   supabase secrets set STRIPE_PRO_SOLO_PRICE_ID=price_...    # Individual teacher Pro plan
#   supabase secrets set STRIPE_PRO_STUDIO_PRICE_ID=price_...  # Studio/business Pro plan
# Optional fallback if you only have one Pro price:
#   supabase secrets set STRIPE_PRO_PRICE_ID=price_...

# Error monitoring (Sentry). Optional: leave unset and monitoring stays a no-op
# (no network, no overhead). Set it in the production environment to capture
# uncaught errors, ErrorBoundary crashes, and logger.error(...) calls.
#   Create a Browser/React project in Sentry and copy its DSN.
# VITE_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>

# Pre-launch gate. When 'true', the /auth signup route redirects to the
# landing page and the landing page shows the waitlist instead of sign-up CTAs.
# MUST be set explicitly in the production environment (Vercel) — if unset it
# defaults to OFF, which makes signup live. Set to 'false' only when you intend
# to open signups for real.
VITE_PRELAUNCH=true

# Optional: Feature flags
# VITE_ENABLE_REALTIME=false
# VITE_ENABLE_ANALYTICS=false

# Optional: Pagination defaults
# VITE_DEFAULT_PAGE_SIZE=20
